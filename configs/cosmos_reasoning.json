{
  "app": {
    "database_path": "data/cosmos-observability.sqlite3",
    "incident_window_seconds": 900,
    "api_host": "0.0.0.0",
    "api_port": 8080,
    "log_level": "INFO",
    "log_format": "json"
  },
  "worker": {
    "backend": "http://127.0.0.1:8080",
    "adapter": "cosmos-reason2",
    "adapter_endpoint": "http://127.0.0.1:8000/v1",
    "model": "nvidia/cosmos-reason2-2b",
    "api_key_env": "COSMOS_API_KEY",
    "post_events": true
  }
}
